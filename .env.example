# PostgreSQL
POSTGRES_PASSWORD=streamdb_secret

# API
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
BASE_URL=https://streamdb.plaio.cc

# Optional: Override database URL (auto-constructed from POSTGRES_PASSWORD in docker-compose)
# DATABASE_URL=postgres://streamdb:streamdb_secret@postgres:5432/streamdb

# TMDB (metadata enrichment)
TMDB_API_KEY=

# Probe pipeline (server-side RealDebrid key for probing files)
PROBE_RD_API_KEY=
PROBE_INTERVAL_MS=30000

# DHT passive listener
DHT_ENABLED=false
DHT_PORT=6881
